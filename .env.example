# =============================================================================
# CHATBOT AI — ENVIRONMENT CONFIGURATION EXAMPLE
# =============================================================================
# Salin file ini ke .env, isi semua nilai yang diperlukan.
# JANGAN pernah commit file .env ke version control.
# =============================================================================

# -----------------------------------------------------------------------------
# APP DASAR
# -----------------------------------------------------------------------------
APP_NAME="Chatbot AI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP CLI workers untuk development server (tidak relevan di production Nginx/Apache)
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
# Untuk production: gunakan "daily" agar log dirotasi harian
# Gabungkan: LOG_STACK=daily,stderr
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Untuk production gunakan "error" atau "warning" — jangan "debug"
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Production: gunakan MySQL/MariaDB, bukan SQLite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chatbot_ai
DB_USERNAME=chatbot_user
DB_PASSWORD=your_strong_db_password_here

# SQLite (hanya untuk development lokal)
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# -----------------------------------------------------------------------------
# SESSION
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# QUEUE & CACHE
# -----------------------------------------------------------------------------
# Production: gunakan "redis" jika tersedia, "database" jika tidak
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=chatbot_ai

# Redis (aktifkan jika menggunakan Redis untuk queue/cache)
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# BROADCAST & FILESYSTEM
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# MAIL (digunakan jika ada notifikasi email; default: log untuk development)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# AWS S3 (opsional, jika menggunakan cloud storage)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# WHATSAPP CLOUD API (Meta)
# -----------------------------------------------------------------------------
# Dapatkan dari Meta for Developers → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Token untuk verifikasi webhook saat Meta melakukan GET request
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here
# Secret untuk validasi signature X-Hub-Signature-256 pada POST webhook
WHATSAPP_WEBHOOK_SECRET=your_webhook_app_secret_here
# Base URL Graph API (jangan diubah kecuali Meta merilis versi baru)
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com/v19.0
# Kode negara default untuk normalisasi nomor telepon
WHATSAPP_DEFAULT_COUNTRY_CODE=62

# -----------------------------------------------------------------------------
# OPENAI / LLM
# -----------------------------------------------------------------------------
# Dapatkan dari platform.openai.com → API Keys
OPENAI_API_KEY=sk-your_openai_api_key_here
# Model untuk setiap fungsi AI (gpt-4o-mini hemat biaya untuk production)
OPENAI_MODEL_INTENT=gpt-4o-mini
OPENAI_MODEL_EXTRACTION=gpt-4o-mini
OPENAI_MODEL_REPLY=gpt-4o-mini
OPENAI_MODEL_SUMMARY=gpt-4o-mini

# -----------------------------------------------------------------------------
# HUBSPOT CRM (opsional)
# -----------------------------------------------------------------------------
# Kosongkan jika tidak menggunakan HubSpot; sistem akan berjalan local-only
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here
HUBSPOT_BASE_URL=https://api.hubapi.com

# -----------------------------------------------------------------------------
# CHATBOT FEATURE FLAGS
# -----------------------------------------------------------------------------
# true = wajib role admin untuk akses dashboard
CHATBOT_REQUIRE_ADMIN=true
# true = operator dapat melakukan takeover/release/escalation
CHATBOT_ALLOW_OPERATOR_ACTIONS=true
# true = aktifkan notifikasi operasional ke admin (takeover, eskalasi, dll)
CHATBOT_NOTIFICATIONS_ENABLED=true
# true = catat semua aksi admin ke audit log
CHATBOT_AUDIT_ENABLED=true
# true = gunakan knowledge base untuk augmentasi reply AI
CHATBOT_KNOWLEDGE_ENABLED=true
# true = evaluasi dan catat kualitas jawaban AI
CHATBOT_AI_QUALITY_ENABLED=true
# Threshold confidence AI: reply di bawah nilai ini dianggap low-confidence
CHATBOT_AI_LOW_CONFIDENCE_THRESHOLD=0.40
# Maksimum percobaan kirim pesan sebelum dianggap failed
CHATBOT_MAX_SEND_ATTEMPTS=3
# Cooldown sebelum pesan yang gagal boleh di-resend (menit)
CHATBOT_RESEND_COOLDOWN_MINUTES=5

# -----------------------------------------------------------------------------
# RELIABILITY / HEALTH CHECK
# -----------------------------------------------------------------------------
# Alert jika jumlah job di queue melebihi threshold ini
CHATBOT_HEALTH_QUEUE_BACKLOG_THRESHOLD=50
# Alert jika jumlah pesan gagal terkirim melebihi threshold ini
CHATBOT_HEALTH_FAILED_MESSAGE_THRESHOLD=10
# Alert jika jumlah eskalasi terbuka melebihi threshold ini
CHATBOT_HEALTH_OPEN_ESCALATION_THRESHOLD=20

# -----------------------------------------------------------------------------
# CLEANUP RETENTION
# -----------------------------------------------------------------------------
# Hapus notifikasi yang sudah dibaca lebih dari N hari
CHATBOT_CLEANUP_READ_NOTIFICATIONS_DAYS=30
# Hapus audit log lebih dari N hari
CHATBOT_CLEANUP_AUDIT_LOGS_DAYS=90
# Hapus AI log lebih dari N hari
CHATBOT_CLEANUP_AI_LOGS_DAYS=60
# Hapus eskalasi closed lebih dari N hari
CHATBOT_CLEANUP_CLOSED_ESCALATIONS_DAYS=90
# true = cleanup hanya preview (dry-run), false = eksekusi sungguhan
CHATBOT_CLEANUP_DRY_RUN_DEFAULT=true

# -----------------------------------------------------------------------------
# VITE (Frontend build — tidak digunakan di production server)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
